{
  "name": "string-query-builder",
  "version": "1.0.0",
  "description": "A lightweight, functional query builder with template literal and pipe support.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dprawin/string-query-builder.git"
  },
  "keywords": [
    "query-builder",
    "template-literals",
    "json-query",
    "pipes"
  ],
  "author": "Praveen Dodda",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dprawin/string-query-builder/issues"
  },
  "homepage": "https://github.com/dprawin/string-query-builder#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
